{
    "name": "phpdot/qrcode",
    "description": "Coroutine-safe QR code generation with SVG, PNG and data-URI renderers for the PHPdot ecosystem.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Omar Hamdan",
            "email": "omar@phpdot.com"
        }
    ],
    "keywords": ["qrcode", "qr", "svg", "png", "phpdot"],
    "require": {
        "php": ">=8.3",
        "ext-gd": "*",
        "bacon/bacon-qr-code": "^3.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpdot/container": "^1.7",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PHPdot\\QrCode\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPdot\\QrCode\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit=256M",
        "cs-fix": "php-cs-fixer fix",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "check": [
            "@test",
            "@analyse",
            "@cs-check"
        ]
    },
    "config": {
        "sort-packages": true
    }
}
